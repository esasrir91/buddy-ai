# ─────────────────────────────────────────────────────────────────────────────
# Buddy AI — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit a .env file with real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── Buddy Platform ────────────────────────────────────────────────────────────
BUDDY_API_KEY=your_buddy_api_key_here
BUDDY_WORKSPACE_ID=your_workspace_id
BUDDY_WORKSPACE_NAME=my-workspace
BUDDY_WORKSPACE_ROOT=./workspace
BUDDY_API_RUNTIME=cloud          # cloud | local

# ── LLM Providers (add only what you use) ────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
COHERE_API_KEY=...
GROQ_API_KEY=gsk_...
MISTRAL_API_KEY=...
TOGETHER_API_KEY=...
FIREWORKS_API_KEY=...
PERPLEXITY_API_KEY=pplx-...
XAI_API_KEY=...
DEEPSEEK_API_KEY=...
DEEPINFRA_API_KEY=...
CEREBRAS_API_KEY=...

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1
AWS_REGION=us-east-1
# AWS_PROFILE=default           # Optional: use a named profile

# ── Azure OpenAI ─────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Vector Databases ─────────────────────────────────────────────────────────
PINECONE_API_KEY=...
PINECONE_ENVIRONMENT=us-east-1-aws
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=...
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=...
MILVUS_URI=http://localhost:19530

# ── Storage Backends ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/buddy
REDIS_URL=redis://localhost:6379/0
MONGODB_URI=mongodb://localhost:27017/buddy

# ── Tool Integrations ────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
DISCORD_BOT_TOKEN=...
TAVILY_API_KEY=tvly-...
SERPER_API_KEY=...
E2B_API_KEY=...

# ── Search & Web ─────────────────────────────────────────────────────────────
FIRECRAWL_API_KEY=...
BROWSERBASE_API_KEY=...

# ── Playground UI ────────────────────────────────────────────────────────────
APP_PASSWORD=                    # Optional: password-protect the playground

# ── Training ─────────────────────────────────────────────────────────────────
HUGGINGFACE_TOKEN=hf_...
WANDB_API_KEY=...                # Optional: Weights & Biases experiment tracking
